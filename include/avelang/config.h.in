#pragma once

// ave-lang build configuration
// This file is generated by CMake from config.h.in

// CUDA support
#cmakedefine WITH_CUDA

// AMDGPU support
#cmakedefine WITH_AMDGPU

// ROCm installation paths (when AMDGPU support enabled)
#ifdef WITH_AMDGPU
#define ROCM_ROOT_PATH "@ROCM_ROOT_PATH@"
#define ROCM_DEVICE_LIBRARY_PATH "@ROCM_DEVICE_LIBRARY_PATH@"
#define ROCM_TOOL_PATHS "@ROCM_TOOL_PATHS@"
#endif

// Version information
#define AVE_LANG_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define AVE_LANG_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define AVE_LANG_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define AVE_LANG_VERSION_STRING "@PROJECT_VERSION@"